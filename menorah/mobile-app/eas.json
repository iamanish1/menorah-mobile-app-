{
  "cli": {
    "version": ">= 3.14.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.menorahhealth.app/api",
        "EXPO_PUBLIC_JITSI_BASE_URL": "https://meet.jit.si",
        "EXPO_PUBLIC_CHECKOUT_RETURN_URL": "https://menorahhealth.app/checkout/return"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.menorahhealth.app/api",
        "EXPO_PUBLIC_JITSI_BASE_URL": "https://meet.jit.si",
        "EXPO_PUBLIC_CHECKOUT_RETURN_URL": "https://menorahhealth.app/checkout/return"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.menorahhealth.app/api",
        "EXPO_PUBLIC_JITSI_BASE_URL": "https://meet.jit.si",
        "EXPO_PUBLIC_CHECKOUT_RETURN_URL": "https://menorahhealth.app/checkout/return"
      }
    }
  }
}
